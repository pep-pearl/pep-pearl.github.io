export type LinkItem = {
  label: string
  href: string
  kind: 'email' | 'github' | 'blog' | 'linkedin' | 'resume' | 'external'
}

export type SkillGroup = {
  title: string
  items: string[]
}

export type ExperienceItem = {
  role: string
  period: string
  company: string
  summary: string
  tags: string[]
}

export type ProjectCase = {
  title: string
  period?: string
  summary: string
  context: string
  role: string
  decisions: string[]
  stack: string[]
  representation: string[]
}

export type CertificationItem = {
  name: string
  issuer: string
  acquiredAt: string
  visibility: 'confirmed' | 'needs-confirmation'
}

